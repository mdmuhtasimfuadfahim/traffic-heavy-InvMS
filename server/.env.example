# Server
PORT=8977
NODE_ENV=development

# Must exactly match the origin(s) your frontend is served from - scheme,
# host, and port, no trailing slash. Comma-separate multiple origins, e.g.
# your Vercel production domain plus its git-branch preview domain:
#   CLIENT_URL=https://invms.vercel.app,https://invms-git-main-you.vercel.app
CLIENT_URL=http://localhost:5601

# Postgres (Neon in production, local Postgres in development)
# Neon example: postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/invms?sslmode=require
# Put your REAL connection string in a local .env file (gitignored) - never here.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/invms

# Set to "true" to force SSL (Neon requires it). Auto-enabled if DATABASE_URL contains neon.tech.
DB_SSL=false

# Reservation window, in seconds
RESERVATION_WINDOW_SECONDS=60
